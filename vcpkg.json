{
  "name": "alicevision",
  "version": "4.0.0",
  "dependencies": [
    { 
      "name": "alembic",
      "default-features": false
    },
    {
      "name": "assimp",
      "default-features": false
    },
    {
      "name": "boost-atomic",
      "default-features": false
    },
    {
      "name": "boost-container",
      "default-features": false
    },
    {
      "name": "boost-date-time",
      "default-features": false
    },
    {
      "name": "boost-graph",
      "default-features": false
    },
    {
      "name": "boost-json",
      "default-features": false
    },
    {
      "name": "boost-log",
      "default-features": false
    },
    {
      "name": "boost-program-options",
      "default-features": false
    },
    {
      "name": "boost-regex",
      "default-features": false
    },
    {
      "name": "boost-serialization",
      "default-features": false
    },
    {
      "name": "boost-system",
      "default-features": false
    },
    {
      "name": "boost-thread",
      "default-features": false
    },
    {
      "name": "boost-timer",
      "default-features": false
    },
    {
      "name": "boost-test",
      "default-features": false
    },
    {
      "name": "ceres",
      "default-features": false,
      "features": [
        "eigensparse",
        "lapack",
        "schur"
      ]
    },
    {
      "name": "coinutils",
      "default-features": false
    },
    {
      "name": "coin-or-clp",
      "default-features": false
    },
    {
      "name": "eigen3",
      "default-features": false
    },
    {
      "name": "expat",
      "default-features": false
    },
    {
      "name": "flann",
      "default-features": false
    },
    {
      "name": "geogram",
      "default-features": false
    },
    {
      "name": "liblemon",
      "default-features": false
    },
    {
      "name": "libe57format",
      "default-features": false
    },
    {
      "name": "nanoflann",
      "default-features": false
    },
    {
      "name": "onnxruntime",
      "default-features": false
    },
    {
      "name": "opencv",
      "default-features": false,
      "features": [
        "contrib",
        "eigen",
        "jpeg",
        "jpegxl",
        "openexr",
        "openjpeg",
        "png",
        "tiff",
        "webp"
      ]
    },
    {
      "name": "openexr",
      "default-features": false
    },
    {
      "name": "openimageio",
      "default-features": false,
      "features": [
        "gif",
        "jpegxl",
        "libraw",
        "opencolorio",
        "opencv",
        "openjpeg",
        "webp"
      ]
    },
    {
      "name": "coin-or-osi",
      "default-features": false
    },
    {
      "name": "usd",
      "default-features": false,
      "features": [
        "imaging"
      ]
    },
    {
      "name": "zlib",
      "default-features": false
    },
    {
      "name": "apriltag",
      "default-features": false
    }
  ],
  "features": {
    "allow-gpl": {
      "description": "Allows linking to GPL-licensed code",
      "dependencies": [
        {
          "name": "ceres",
          "default-features": false,
          "features": [
            "suitesparse"
          ]
        },
        {
          "name": "openimageio",
          "default-features": false,
          "features": [
            "libheif"
          ]
        }
      ]
    },
    "video-codecs": {
      "description": "Pulls in ffmpeg to support decoding of video streams",
      "dependencies": [
        {
          "name": "opencv",
          "default-features": false,
          "features": [
            "ffmpeg"
          ]
        },
        {
          "name": "openimageio",
          "default-features": false,
          "features": [
            "ffmpeg"
          ]
        }
      ]
    }
  }
}
