# =============================================================================
# blas-extra.cmake - This file helps creating the BLAS targets and variables
# on Windows if ALICEVISION_OPENBLAS_PREBUILT is set.
# =============================================================================

if(NOT TARGET BLAS::BLAS)

    if(NOT WIN32)
        message(FATAL_ERROR "Unable to use blas-extra.cmake on a platform other than Windows!")
    endif()

    # The behavior differs between Windows on ARM and x86_64 Windows
    # x86_64 Windows also has the libraries prefixed with "lib"

    if(CMAKE_SYSTEM_PROCESSOR MATCHES "(AMD64|IA64)")
        if(BUILD_SHARED_LIBS)
            add_library(BLAS::BLAS SHARED IMPORTED GLOBAL)
            set_target_properties(BLAS::BLAS PROPERTIES
                IMPORTED_IMPLIB "@PROJECT_BINARY_DIR@/_deps/blas-src/lib/libopenblas.lib"
                IMPORTED_LOCATION "@PROJECT_BINARY_DIR@/_deps/blas-src/bin/libopenblas.dll"
            )
            set(BLAS_LIBRARIES "@PROJECT_BINARY_DIR@/_deps/blas-src/lib/libopenblas.lib" CACHE STRING "The BLAS libraries" FORCE)
            set(ENV{PATH} "@PROJECT_BINARY_DIR@/_deps/blas-src/bin/libopenblas.dll;$ENV{PATH}")
        else()
            add_library(BLAS::BLAS STATIC IMPORTED GLOBAL)
            set_target_properties(BLAS::BLAS PROPERTIES
                IMPORTED_LOCATION "@PROJECT_BINARY_DIR@/_deps/blas-src/bin/libopenblas.a"
            )
            set(BLAS_LIBRARIES "@PROJECT_BINARY_DIR@/_deps/blas-src/lib/libopenblas.a" CACHE STRING "The BLAS libraries" FORCE)
        endif()
    elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "ARM64")
        if(BUILD_SHARED_LIBS)
            add_library(BLAS::BLAS SHARED IMPORTED GLOBAL)
            set_target_properties(BLAS::BLAS PROPERTIES
                IMPORTED_IMPLIB "@PROJECT_BINARY_DIR@/_deps/blas-src/lib/openblas.lib"
                IMPORTED_LOCATION "@PROJECT_BINARY_DIR@/_deps/blas-src/bin/openblas.dll"
            )
            set(BLAS_LIBRARIES "@PROJECT_BINARY_DIR@/_deps/blas-src/lib/openblas.lib" CACHE STRING "The BLAS libraries" FORCE)
            set(ENV{PATH} "@PROJECT_BINARY_DIR@/_deps/blas-src/bin/libopenblas.dll;$ENV{PATH}")
        else()
            add_library(BLAS::BLAS STATIC IMPORTED GLOBAL)
            set_target_properties(BLAS::BLAS PROPERTIES
                IMPORTED_LOCATION "@PROJECT_BINARY_DIR@/_deps/blas-src/lib/openblas.lib"
            )
            set(BLAS_LIBRARIES "@PROJECT_BINARY_DIR@/_deps/blas-src/lib/openblas.lib" CACHE STRING "The BLAS libraries" FORCE)
        endif()
    endif()

    set(BLA_VENDOR "OpenBLAS" CACHE STRING "The vendor of the BLAS" FORCE)
    set(BLA_SIZEOF_INTEGER 4 CACHE STRING "Specifies the BLAS/LAPACK library integer size" FORCE)

endif()
