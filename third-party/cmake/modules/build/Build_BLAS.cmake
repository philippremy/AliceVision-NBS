# =============================================================================
# Build_BLAS.cmake - Integrates an embedded OpenBLAS/LAPACK into the project
#
# NOTE:
# We essentially provide the same level of support that the FindBLAS and
# FindLAPACK modules from CMake provide. This means: Only the target is exposed
# and we especially do not have any public include directories (the modules do
# not expose these either). From what we know neither SuiteSparse nor Ceres
# explicitly include the BLAS/LAPACK headers, so it should be fine. Therefore
# we also do not build the C interfaces for BLAS/LAPACK, because our
# dependencies link directly against the FORTRAN(-compatible) code.
#
# Special cases considered:
# - Windows is more complicated because we need to avoid Fortran (see below)
# - Create the BLAS::BLAS target and set the BLAS_* variables
# - Sets AV_BLAS_IS_EMBEDDED, so the project knows that BLAS/LAPACK are built
# embedded
# - Create a pkg_redirects file for LAPACK, to ensure that the fresh LAPACK
#   is used.
# - Create the LAPACK::LAPACK target and set the LAPACK_* variables
# =============================================================================

include(${CMAKE_CURRENT_SOURCE_DIR}/cmake/modules/utils/IntegrateDependency.cmake)

# Building universal binaries is not supported and likely never needed
if(AV_IS_APPLE_UNIVERSAL_BUILD)
  message(FATAL_ERROR "Building a universal OpenBLAS/LAPACK is not supported! Make sure to use Accelerate.framework (you likely need to remove ALICEVISION_FORCE_BUILD_BLAS and ALICEVISION_FORCE_BUILD_LAPACK)")
endif()

# OpenBLAS can go two ways if the target is Windows:
# (1) Use pre-built binaries
# (2) Build from source and use a LAPACK implementation in C, generated by f2c
# There is no real advantage from one over the other, so it is the users choice
# which way to go. For default, we built the C-based LAPACK.

if(ALICEVISION_OPENBLAS_PREBUILT)

  # Determine which file to download (essentially whether this is Windows on ARM
  # or regular x86_64 Windows)
  if(CMAKE_SYSTEM_PROCESSOR MATCHES "(AMD64|IA64)")
    set(AV_OPENBLAS_FILENAME "OpenBLAS-0.3.33-x64.zip")
    set(AV_OPENBLAS_FILEHASH "SHA256=7ad797ef0c9a5c42e28903bf726eaaaade307dafe187ff0e923d90cd4002780c")
  elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "ARM64" AND BUILD_STATIC_LIBS)
    set(AV_OPENBLAS_FILENAME "OpenBLAS-0.3.33-woa64-static.zip")
    set(AV_OPENBLAS_FILEHASH "SHA256=16c3b3d637b7489ba5cca3e945ef555f5f189d2b5e89e07b0965c8da5ff20009")
  elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "ARM64" AND BUILD_SHARED_LIBS)
    set(AV_OPENBLAS_FILENAME "OpenBLAS-0.3.33-woa64-dll.zip")
    set(AV_OPENBLAS_FILEHASH "SHA256=bdb1047eb24a17c38d20eda6aa3fe5a9d74fd4ad95432f452bfa2ae28a9227d0")
  else()
    message(FATAL_ERROR "Encountered unknown CMAKE_SYSTEM_PROCESSOR (${CMAKE_SYSTEM_PROCESSOR}) when determining which pre-built binary of OpenBLAS to download for Windows!")
  endif()

  # Download and extract it
  FetchContent_Declare(blas
    URL "https://github.com/OpenMathLib/OpenBLAS/releases/download/v0.3.33/${AV_OPENBLAS_FILENAME}"
    URL_HASH "${AV_OPENBLAS_FILEHASH}"
  )
  FetchContent_MakeAvailable(blas)

  # We must write our own blas-config.cmake and lapack-config.cmake files to
  # CMAKE_FIND_PACKAGE_REDIRECTS_DIR
  # Version file
  file(WRITE "${CMAKE_FIND_PACKAGE_REDIRECTS_DIR}/blas-config-version.cmake"
[=[
# Automatically generated by CMake's FetchContent module.
# Do not edit this file, it will be regenerated every time CMake runs.

# Version not available, assuming it is compatible. We must also say it is an
# exact match to ensure find_package() calls with the EXACT keyword still get
# redirected.
set(PACKAGE_VERSION_COMPATIBLE TRUE)
set(PACKAGE_VERSION_EXACT TRUE)
]=]
  )

  # Config file
  file(WRITE "${CMAKE_FIND_PACKAGE_REDIRECTS_DIR}/blas-config.cmake"
[=[
# Automatically generated by CMake's FetchContent module.
# Do not edit this file, it will be regenerated every time CMake runs.

# Projects or the dependencies themselves can provide the following files.
# The files should define any additional commands or variables that the
# dependency would normally provide but which won't be available globally
# if the dependency is brought into the build via FetchContent instead.
# For dependencies that only provide imported targets and no commands,
# these typically won't be needed.
include("${CMAKE_CURRENT_LIST_DIR}/blas-extra.cmake" OPTIONAL)
include("${CMAKE_CURRENT_LIST_DIR}/BLASExtra.cmake" OPTIONAL)
]=]
  )

  # Extra file
  configure_file(
    ${CMAKE_CURRENT_SOURCE_DIR}/cmake/templates/blas-extra.cmake.in
    ${CMAKE_FIND_PACKAGE_REDIRECTS_DIR}/blas-extra.cmake
    @ONLY
  )

  # Version file
  file(WRITE "${CMAKE_FIND_PACKAGE_REDIRECTS_DIR}/lapack-config-version.cmake"
[=[
# Automatically generated by CMake's FetchContent module.
# Do not edit this file, it will be regenerated every time CMake runs.

# Version not available, assuming it is compatible. We must also say it is an
# exact match to ensure find_package() calls with the EXACT keyword still get
# redirected.
set(PACKAGE_VERSION_COMPATIBLE TRUE)
set(PACKAGE_VERSION_EXACT TRUE)
]=]
  )

  # Config file
  file(WRITE "${CMAKE_FIND_PACKAGE_REDIRECTS_DIR}/lapack-config.cmake"
[=[
# Automatically generated by CMake's FetchContent module.
# Do not edit this file, it will be regenerated every time CMake runs.

# Projects or the dependencies themselves can provide the following files.
# The files should define any additional commands or variables that the
# dependency would normally provide but which won't be available globally
# if the dependency is brought into the build via FetchContent instead.
# For dependencies that only provide imported targets and no commands,
# these typically won't be needed.
include("${CMAKE_CURRENT_LIST_DIR}/lapack-extra.cmake" OPTIONAL)
include("${CMAKE_CURRENT_LIST_DIR}/LAPACKExtra.cmake" OPTIONAL)
]=]
  )

  # Extra file
  configure_file(
    ${CMAKE_CURRENT_SOURCE_DIR}/cmake/templates/lapack-extra.cmake.in
    ${CMAKE_FIND_PACKAGE_REDIRECTS_DIR}/lapack-extra.cmake
    @ONLY
  )

else()

  # Not on Windows or building the Windows BLAS/C-LAPACK
  alicevision_integrate_dependency(BLAS
      SUBMODULE_NAME "OpenBLAS"
      PATCH_STEP
        "${CMAKE_CURRENT_SOURCE_DIR}/cmake/modules/build/patch/OpenBLAS-CMakeBinaryDir-ArchiveAndLibraryOutputFolder-DarwinLinkerSysroot.patch"
      CMAKE_EVAL_CODE
        "set(INTERFACE64 OFF)"
        "set(BUILD_WITHOUT_LAPACK OFF)"
        "set(BUILD_WITHOUT_LAPACKE ON)"
        "set(BUILD_LAPACK_DEPRECATED ON)"
        "set(BUILD_TESTING OFF)"
        "set(BUILD_BENCHMARKS OFF)"
        "set(C_LAPACK ${ALICEVISION_USE_C_LAPACK})"
        "set(NOFORTRAN ${ALICEVISION_USE_C_LAPACK})"
        "set(BUILD_WITHOUT_CBLAS ON)"
        "set(DYNAMIC_ARCH OFF)" # TODO: Activate for distribution builds
        "set(DYNAMIC_OLDER OFF)"
        "set(BUILD_RELAPACK OFF)"
        "set(USE_LOCKING OFF)"
        "set(USE_PERL OFF)"
        "set(FIXED_LIBNAME OFF)"
        "set(CPP_THREAD_SAFETY_TEST OFF)"
        "set(CPP_THREAD_SAFETY_GEMV OFF)"
        "set(BUILD_STATIC_LIBS ${BUILD_STATIC_LIBS})"
        "set(BUILD_SHARED_LIBS ${BUILD_SHARED_LIBS})"
        # See the note in Ceres that BLAS/LAPACK cannot be used with threading
        # enabled because it uses its own threading model which interferes with
        # the OpenBLAS threading model.
        "set(USE_THREAD OFF)"
        "set(USE_OPENMP OFF)"
  )

  # Indicate to the project that BLAS is built embedded
  set(AV_BLAS_IS_EMBEDDED ON CACHE INTERNAL "Whether BLAS/LAPACK is built embedded instead of using an externally provided BLAS/LAPACK")

  # Add BLAS CMake module compatibility
  if(NOT TARGET BLAS::BLAS)

    # Switch on whether the libraries are shared or static
    if(BUILD_SHARED_LIBS)
      add_library(__blas_interface INTERFACE)
      target_link_libraries(__blas_interface INTERFACE openblas_shared)
      add_library(BLAS::BLAS ALIAS __blas_interface)
    elseif(BUILD_STATIC_LIBS)
      add_library(__blas_interface INTERFACE)
      target_link_libraries(__blas_interface INTERFACE openblas_static)
      add_library(BLAS::BLAS ALIAS __blas_interface)
    endif()

    # Add the LAPACK variables which are expected to be available
    # BLAS95 should not be set I guess
    set(BLAS_FOUND ON CACHE BOOL "Whether BLAS was found")
    set(BLAS_LINKER_FLAGS BLAS::BLAS CACHE STRING "Which flags to pass to target_link_libraries to link to BLAS")
    set(BLAS_LIBRARIES BLAS::BLAS CACHE STRING "Which libraries to link against to use BLAS")

    # This is useful for SuiteSparse to assume that our freshly built BLAS is
    # an OpenBLAS implementation, which internally correctly sets
    # BLA_SIZEOF_INTEGER correctly. If not built, SuiteSparse can find any BLAS.
    set(BLA_VENDOR OpenBLAS CACHE STRING "The vendor of the BLAS/LAPACK")
    set(BLA_SIZEOF_INTEGER 4 CACHE STRING "The size of an integer in the BLAS in bytes")

  endif()

  # Add the pkg redirect for LAPACK
  if(NOT TARGET LAPACK::LAPACK)

    # Version file
    file(WRITE "${CMAKE_FIND_PACKAGE_REDIRECTS_DIR}/lapack-config-version.cmake"
[=[
# Automatically generated by CMake's FetchContent module.
# Do not edit this file, it will be regenerated every time CMake runs.

# Version not available, assuming it is compatible. We must also say it is an
# exact match to ensure find_package() calls with the EXACT keyword still get
# redirected.
set(PACKAGE_VERSION_COMPATIBLE TRUE)
set(PACKAGE_VERSION_EXACT TRUE)
]=]
    )

    # Config file
    file(WRITE "${CMAKE_FIND_PACKAGE_REDIRECTS_DIR}/lapack-config.cmake"
[=[
# Automatically generated by CMake's FetchContent module.
# Do not edit this file, it will be regenerated every time CMake runs.

# Projects or the dependencies themselves can provide the following files.
# The files should define any additional commands or variables that the
# dependency would normally provide but which won't be available globally
# if the dependency is brought into the build via FetchContent instead.
# For dependencies that only provide imported targets and no commands,
# these typically won't be needed.
include("${CMAKE_CURRENT_LIST_DIR}/lapack-extra.cmake" OPTIONAL)
include("${CMAKE_CURRENT_LIST_DIR}/LAPACKExtra.cmake" OPTIONAL)
]=]
    )

    # Add the LAPACK variables which are expected to be available
    # LAPACK95 should not be set I guess
    add_library(__lapack_interface INTERFACE)
    target_link_libraries(__lapack_interface INTERFACE BLAS::BLAS lapack)
    add_library(LAPACK::LAPACK ALIAS __lapack_interface)
    set(LAPACK_FOUND ON CACHE BOOL "Whether LAPACK was found")
    set(LAPACK_LINKER_FLAGS LAPACK::LAPACK CACHE STRING "Which flags to pass to target_link_libraries to link to LAPACK")
    set(LAPACK_LIBRARIES LAPACK::LAPACK CACHE STRING "Which libraries to link against to use LAPACK")

  endif()

endif()
